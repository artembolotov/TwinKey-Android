# Copy this file to local.properties and fill in your values.
# local.properties is gitignored and will never be committed.

# Android SDK path (set automatically by Android Studio)
# sdk.dir=/Users/username/Library/Android/sdk

# AppMetrica API key for local builds.
# Get it from AppMetrica dashboard: https://appmetrica.io
# Leave empty or omit to disable analytics in local builds.
sdk.dir=/path/to/Android/sdk
appmetrica.api.key=your_key_here
